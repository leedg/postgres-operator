# EditorConfig — keep tabs/spaces consistent regardless of editor.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs — gofmt enforces, but make editors agree too.
[*.go]
indent_style = tab
indent_size = 4

# Makefiles require tabs (or make refuses to parse).
[Makefile]
indent_style = tab

# Shell scripts.
[*.{sh,bash}]
indent_size = 4

# Markdown allows trailing whitespace as a forced line break.
[*.md]
trim_trailing_whitespace = false

# Helm templates and Kubernetes YAML are 2-space (matches kustomize).
[*.{yaml,yml,json}]
indent_size = 2
