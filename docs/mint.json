        "concepts/metadata-sync",
        "concepts/version-matrix"
      ]
    },
    {
      "group": "How-to",
      "pages": [
        "how-to/backup-pitr",
        "how-to/shard-rebalance",
        "how-to/zone-sharding",
        "how-to/upgrade",
        "how-to/migrate-from-cnpg"
      ]
    },
    {
      "group": "Reference",
      "pages": ["reference/crd-overview", "reference/cli", "reference/metrics"]
    },
    {
      "group": "Operator Guide",
      "pages": [
        "operator-guide/deployment",
        "operator-guide/ha-election",
        "operator-guide/pooler-monitoring",
        "operator-guide/cross-validation-cnpg"
      ]
    },
    {
      "group": "ADR",
      "pages": [
        "adr/0001-self-built-distributed-sql",
        "adr/0002-single-chart-with-flags",
        "adr/0003-license-policy-no-agpl-busl",
        "adr/0004-crd-managed-by-operator",
        "adr/0005-versioning-and-channels"
      ]
    },
    {
      "group": "RFC",
      "pages": [
        "rfcs/0001-postgrescluster-crd-v2",
