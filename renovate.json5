{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:nonOfficeHours",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Asia/Seoul",
  "labels": ["renovate", "dependencies"],
  "prHourlyLimit": 4,
  "rangeStrategy": "pin",
  "dependencyDashboard": true,
  "ignorePaths": ["**/vendor/**", "**/charts/**"],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["renovate", "major-bump", "needs-review"]
    }
  ]
}
